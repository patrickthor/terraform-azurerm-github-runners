# Copy to terraform.tfvars (which is gitignored) and fill in your values.
#
# Only 7 variables are required — all resource names are auto-generated
# from workload/environment/instance using Azure CAF naming conventions.

# ==============================================================================
# Core (required)
# ==============================================================================
workload    = "runner"       # short identifier, e.g. "runner"
environment = "poc"          # e.g. "poc", "dev", "prod"
instance    = "bvt"          # uniqueness suffix, e.g. "bvt", "001"
location    = "westeurope"
subscription_id = "00000000-0000-0000-0000-000000000000" # az account show --query id -o tsv

# ==============================================================================
# GitHub (required)
# ==============================================================================
github_org  = "your-github-org"
github_repo = "your-github-org/your-repo"

# Key Vault secret names for GitHub App authentication (required)
github_app_id_secret_name              = "github-app-id"
github_app_installation_id_secret_name = "github-app-installation-id"
github_app_private_key_secret_name     = "github-app-private-key"
# webhook_secret_secret_name           = "github-webhook-secret"  # optional

# ==============================================================================
# Auto-generated resource names (override only if needed)
# ==============================================================================
# With workload="runner", environment="poc", instance="bvt" you get:
#   resource_group_name           = "rg-runner-poc-bvt"
#   acr_name                      = "crrunnerpocbvt"
#   aci_name                      = "ci-runner-poc-bvt"
#   key_vault_name                = "kv-runner-poc-bvt"
#   storage_account_name          = "strunnerpocbvt"
#   function_app_name             = "func-runner-poc-bvt"
#   function_storage_account_name = "stfnrunnerpocbvt"
#   servicebus_namespace_name     = "sbns-runner-poc-bvt"
#
# Uncomment to override any name:
# resource_group_name           = "my-custom-rg"
# acr_name                      = "mycustomacr"
# key_vault_name                = "my-custom-kv"
# storage_account_name          = "mycustomst"
# function_app_name             = "my-custom-func"
# function_storage_account_name = "mycustomstfn"
# servicebus_namespace_name     = "my-custom-sbns"
# aci_name                      = "my-custom-ci"

# ==============================================================================
# Optional configuration
# ==============================================================================
# create_resource_group          = true
# create_log_analytics_workspace = true
# log_analytics_retention_days   = 30
# subnet_id                      = null
# enable_public_network_access   = true
# cpu                            = 2
# memory                         = 4
# runner_min_instances            = 0
# runner_max_instances            = 5
# max_runner_runtime_hours        = 2
# runner_completed_ttl_minutes    = 5
# runner_workload_roles           = []
# enable_resource_locks           = false
# tags                            = {}
